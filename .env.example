# Augurian AI Operations — environment variables
# Copy to .env and fill in. Never commit .env.

# --- Anthropic ---
# Create at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Cloud ---
# Path to the service-account JSON key file with access to:
#   - Drive API (read+write on /Augurian Clients/)
#   - Analytics Data API (Viewer on each client GA4 property)
#   - Search Console API
#   - Google Ads API
GOOGLE_APPLICATION_CREDENTIALS=./credentials/augurian-ai-ops-sa.json

# OAuth client for the Drive MCP server (Google's first-party).
# Set up at console.cloud.google.com → APIs & Services → Credentials.
# CRITICAL: OAuth consent screen Audience must be "Internal" — External + Testing
# causes 7-day refresh-token expiry, which is the #1 way these integrations break.
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=

# --- Slack ---
# Bot User OAuth Token (xoxb-...) — install the "Augur" app to the workspace.
# Required scopes: channels:history, channels:read, chat:write, search:read, users:read.
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_AUDIT_CHANNEL=#agent-activity

# --- Optmyzr ---
# Optmyzr API tokens — pull from https://app.optmyzr.com/api
OPTMYZR_API_KEY=

# --- Google Ads ---
# Developer token + OAuth refresh token. Slightly fiddlier than other Google APIs.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- (Whisper removed) ---
# Fireflies exports its own PDF transcript directly to Drive, so no
# re-transcription is needed. If you ever need to handle non-Fireflies audio,
# reintroduce OPENAI_API_KEY here and add the openai dep back to pyproject.toml.

# --- Runtime ---
# DRY_RUN=true skips all external writes (Drive, Slack, Notion). Use during dev.
DRY_RUN=false
LOG_LEVEL=INFO
